# Direct database mode
ATTENDANCE_DB_CONNECTION="Server=your-hostinger-server;Port=3306;Database=your-database-name;User ID=your-database-user;Password=your-database-password;SslMode=Preferred;"
SCHOOL_DB_CONNECTION="Server=your-school-db-server;Port=3306;Database=your-school-db-name;User ID=your-school-db-user;Password=your-school-db-password;SslMode=Preferred;"
# Optional: set true to make the school database the only employee source and lock local employee management.
ATTENDANCE_SCHOOL_EMPLOYEES_ONLY=false

# Supabase API mode
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_USE_API=false

# App bootstrap
ATTENDANCE_BOOTSTRAP_ADMIN_PASSWORD="ChangeMe#2026!"
ATTENDANCE_ENABLE_DEMO_ACCOUNTS=false
