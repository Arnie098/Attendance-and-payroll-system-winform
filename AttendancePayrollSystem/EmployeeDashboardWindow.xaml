<Window x:Class="AttendancePayrollSystem.EmployeeDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Dashboard"
        Height="900"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="8,8,8,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Employee Dashboard" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding WelcomeText}" FontSize="14" Foreground="#374151" Margin="0,0,0,2" />
                <TextBlock Text="{Binding TodayText}" FontSize="13" Foreground="#6B7280" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Refresh"
                        Width="110"
                        Style="{StaticResource ModernButton}"
                        Click="Refresh_Click" />
                <Button Content="{Binding ClockActionButtonText}"
                        Width="130"
                        Style="{StaticResource ModernButton}"
                        IsEnabled="{Binding IsClockActionEnabled}"
                        Click="ClockAction_Click" />
                <Button Content="Logout"
                        Width="100"
                        Style="{StaticResource ModernButton}"
                        Click="Logout_Click" />
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="8,0,8,14">
            <Border Style="{StaticResource ModernCard}" Background="#EFF6FF" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border Width="120"
                                Height="120"
                                CornerRadius="60"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                Background="#DBEAFE"
                                ClipToBounds="True"
                                Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="No Photo"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#475569"
                                           FontWeight="SemiBold" />
                                <Image Source="{Binding ProfileImage, Converter={StaticResource ByteToImage}}"
                                       Stretch="UniformToFill" />
                            </Grid>
                        </Border>

                        <Button Content="Change Photo"
                                Width="118"
                                Style="{StaticResource ModernButton}"
                                Click="ChangePhoto_Click" />
                        <Button Content="Remove Photo"
                                Width="118"
                                Style="{StaticResource ModernButton}"
                                Background="#64748B"
                                IsEnabled="{Binding HasProfileImage}"
                                Click="RemovePhoto_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="My Profile" Foreground="#1E3A8A" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding EmployeeCodeText}" Margin="0,2,0,2" />
                        <TextBlock Text="{Binding PositionText}" Margin="0,2,0,2" />
                        <TextBlock Text="{Binding DepartmentText}" Margin="0,2,0,2" />
                        <TextBlock Text="{Binding HourlyRateText}" Margin="0,2,0,2" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource ModernCard}" Background="#ECFDF5" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Today Attendance" Foreground="#166534" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding AttendanceStatusText}" FontWeight="SemiBold" Margin="0,2,0,8" />
                    <TextBlock Text="{Binding TimeInText, StringFormat='Time In: {0}'}" Margin="0,2,0,2" />
                    <TextBlock Text="{Binding TimeOutText, StringFormat='Time Out: {0}'}" Margin="0,2,0,2" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource ModernCard}" Background="#FFF7ED">
                <StackPanel>
                    <TextBlock Text="Latest Payroll" Foreground="#9A3412" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding LatestPayrollText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="My Attendance History" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AttendanceHistory}"
                              Style="{StaticResource ModernDataGrid}"
                              Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding AttendanceDate, StringFormat=yyyy-MM-dd}" Width="130" />
                            <DataGridTextColumn Header="Time In" Binding="{Binding TimeIn, StringFormat=HH:mm:ss}" Width="120" />
                            <DataGridTextColumn Header="Time Out" Binding="{Binding TimeOut, StringFormat=HH:mm:ss}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                            <DataGridTextColumn Header="Hours" Binding="{Binding TotalHours, StringFormat=N2}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="My Payroll Records" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PayrollHistory}"
                              Style="{StaticResource ModernDataGrid}"
                              Margin="0,8,0,0"
                              VerticalAlignment="Stretch"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Period Start" Binding="{Binding PayPeriodStart, StringFormat=yyyy-MM-dd}" Width="120" />
                            <DataGridTextColumn Header="Period End" Binding="{Binding PayPeriodEnd, StringFormat=yyyy-MM-dd}" Width="120" />
                            <DataGridTextColumn Header="Regular Hrs" Binding="{Binding RegularHours, StringFormat=N2}" Width="95" />
                            <DataGridTextColumn Header="OT Hrs" Binding="{Binding OvertimeHours, StringFormat=N2}" Width="85" />
                            <DataGridTextColumn Header="Gross" Binding="{Binding GrossPay, StringFormat=PHP {0:N2}}" Width="120" />
                            <DataGridTextColumn Header="Deductions" Binding="{Binding Deductions, StringFormat=PHP {0:N2}}" Width="120" />
                            <DataGridTextColumn Header="Net Pay" Binding="{Binding NetPay, StringFormat=PHP {0:N2}}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
