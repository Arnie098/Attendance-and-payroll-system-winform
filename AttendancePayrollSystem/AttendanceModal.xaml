<Window x:Class="AttendancePayrollSystem.AttendanceModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Biometric Attendance"
        Height="760" Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1.95*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
            <TextBlock Text="{Binding HeaderText}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding EmployeeNameText}" FontSize="14" Foreground="#4E5968" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Biometric Scanner" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

                <Border Grid.Row="1" Background="#0B172A" CornerRadius="10" Padding="16" MinHeight="170">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <materialDesign:PackIcon Kind="Fingerprint" Width="92" Height="92" Foreground="#00E5FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <ProgressBar Grid.Row="1"
                                     Height="6"
                                     Margin="4,8,4,0"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2" Text="{Binding ScanStateText}" FontWeight="SemiBold" Margin="0,10,0,2" />
                <TextBlock Grid.Row="3" Text="{Binding LastScanText}" FontSize="12" Foreground="#5C6675" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="10" Padding="16">
            <TabControl>
                <TabItem Header="Today Summary">
                    <StackPanel Margin="8">
                        <TextBlock Text="Attendance Summary" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <TextBlock Text="Today Time In" FontWeight="SemiBold" />
                        <TextBox Text="{Binding TimeInText}" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,4,0,10" />

                        <TextBlock Text="Today Time Out" FontWeight="SemiBold" />
                        <TextBox Text="{Binding TimeOutText}" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,4,0,10" />

                        <TextBlock Text="Next Action" FontWeight="SemiBold" />
                        <TextBox Text="{Binding NextActionText}" Style="{StaticResource ModernTextBox}" IsReadOnly="True" Margin="0,4,0,10" />

                        <Border Background="#EEF2F8" CornerRadius="8" Padding="10">
                            <TextBlock Text="{Binding StatusText}" Foreground="#2D3748" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Attendance CRUD">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <Button Content="Refresh" Style="{StaticResource ModernButton}" Width="100" Click="RefreshAttendanceCrud_Click" />
                            <Button Content="Clear" Style="{StaticResource ModernButton}" Width="100" Margin="8,0,0,0" Click="ClearAttendanceCrud_Click" />
                        </StackPanel>

                        <DataGrid x:Name="AttendanceCrudDataGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding AttendanceRecords}"
                                  Style="{StaticResource ModernDataGrid}"
                                  SelectionChanged="AttendanceCrudDataGrid_SelectionChanged"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding AttendanceDate, StringFormat=yyyy-MM-dd}" Width="130" />
                                <DataGridTextColumn Header="Time In" Binding="{Binding TimeIn, StringFormat=HH:mm:ss}" Width="110" />
                                <DataGridTextColumn Header="Time Out" Binding="{Binding TimeOut, StringFormat=HH:mm:ss}" Width="110" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                                <DataGridCheckBoxColumn Header="Biometric" Binding="{Binding IsBiometricVerified}" Width="90" />
                                <DataGridTextColumn Header="Hours" Binding="{Binding TotalHours, StringFormat=N2}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="8" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Attendance Date" Style="{StaticResource SectionTitle}" />
                                    <DatePicker x:Name="CrudDatePicker" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Time In (HH:mm)" Style="{StaticResource SectionTitle}" />
                                    <TextBox x:Name="CrudTimeInTextBox" Style="{StaticResource ModernTextBox}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Text="Time Out (HH:mm)" Style="{StaticResource SectionTitle}" />
                                    <TextBox x:Name="CrudTimeOutTextBox" Style="{StaticResource ModernTextBox}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,0">
                                    <TextBlock Text="Status" Style="{StaticResource SectionTitle}" />
                                    <ComboBox x:Name="CrudStatusComboBox">
                                        <ComboBoxItem Content="Present" />
                                        <ComboBoxItem Content="Late" />
                                        <ComboBoxItem Content="Absent" />
                                        <ComboBoxItem Content="On Leave" />
                                    </ComboBox>
                                </StackPanel>

                                <CheckBox x:Name="CrudBiometricVerifiedCheckBox"
                                          Grid.Row="0"
                                          Grid.Column="4"
                                          Content="Biometric Verified"
                                          VerticalAlignment="Bottom"
                                          Margin="8,0,0,4" />

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="Add" Width="90" Style="{StaticResource ModernButton}" Click="AddAttendanceCrud_Click" />
                                    <Button Content="Update" Width="90" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="UpdateAttendanceCrud_Click" />
                                    <Button Content="Delete" Width="90" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="DeleteAttendanceCrud_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Simulate Fingerprint"
                    Width="170"
                    Margin="0,0,8,0"
                    Style="{StaticResource ModernButton}"
                    IsEnabled="{Binding IsScanButtonEnabled}"
                    Click="BiometricSimulation_Click" />
            <Button Content="Close" Width="100" Style="{StaticResource ModernButton}" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
