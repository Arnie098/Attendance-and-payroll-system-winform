  <connectionStrings>
    <add name="AttendanceDb"
         connectionString="Server=your-hostinger-server;Port=3306;Database=your-database-name;User ID=your-database-user;Password=your-database-password;SslMode=Preferred;"
         providerName="MySqlConnector" />
  </connectionStrings>
</configuration>
