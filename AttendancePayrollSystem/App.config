<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="SupabaseUrl" value="" />
    <add key="SupabasePublishableKey" value="" />
    <add key="SupabaseUseApi" value="false" />
    <add key="BootstrapAdminPassword" value="AdminLogin#2026!" />
    <add key="EnableDemoAccounts" value="false" />
    <add key="DemoEmployeePassword" value="" />
