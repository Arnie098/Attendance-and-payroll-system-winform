<Window x:Class="AttendancePayrollSystem.DatabaseSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Settings"
        Height="640"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="22">
        <Border Style="{StaticResource ModernCard}" Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Database Configuration" Style="{StaticResource HeaderText}" Margin="0,0,0,6" />
                        <TextBlock Text="Use the other laptop's IP address or hostname if the MySQL server is running on another machine."
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Server / IP Address" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="ServerTextBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Port" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="PortTextBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,10">
                        <TextBlock Text="Database Name" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="DatabaseTextBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,0,0,10">
                        <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <TextBox x:Name="UsernameTextBox" Style="{StaticResource ModernTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,0,0,10">
                        <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <PasswordBox x:Name="PasswordBox"
                                     Height="38"
                                     Padding="10,6"
                                     BorderBrush="{StaticResource CardBorderBrush}"
                                     BorderThickness="1" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,0,0,10">
                        <TextBlock Text="SSL Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="SslModeComboBox"
                                  Height="38"
                                  Padding="10,4"
                                  BorderBrush="{StaticResource CardBorderBrush}"
                                  BorderThickness="1" />
                    </StackPanel>

                    <Border Grid.Row="7"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,2,0,10">
                        <TextBlock Text="For another laptop to host the database, that laptop must allow remote MySQL connections and the firewall must allow the port."
                                   Foreground="#475569"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Grid.Row="8"
                               x:Name="StatusTextBlock"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <Button Content="Test Connection"
                                Style="{StaticResource ModernButton}"
                                Width="140"
                                Margin="0,0,8,0"
                                Click="TestConnectionButton_Click" />
                        <Button Content="Use App Default"
                                Style="{StaticResource ModernButton}"
                                Width="140"
                                Background="#0F766E"
                                Click="UseDefaultButton_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="10"
                               Text="Saved settings are stored only on this laptop, so each machine can point to a different database server."
                               Foreground="#64748B"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Save"
                                Width="100"
                                Margin="0,0,8,0"
                                Style="{StaticResource ModernButton}"
                                Click="SaveButton_Click" />
                        <Button Content="Cancel"
                                Width="100"
                                Style="{StaticResource ModernButton}"
                                Click="CancelButton_Click" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
