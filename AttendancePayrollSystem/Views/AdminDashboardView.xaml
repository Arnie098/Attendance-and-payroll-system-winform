<UserControl x:Class="AttendancePayrollSystem.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Admin Dashboard" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding DashboardDateText}" Foreground="#6B7280" FontSize="13" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Backup Database"
                        Style="{StaticResource ModernButton}"
                        Width="150"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="BackupDatabaseButton_Click" />
                <Button Content="Refresh"
                        Style="{StaticResource ModernButton}"
                        Width="110"
                        Height="36"
                        Click="RefreshButton_Click" />
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
            <Border Style="{StaticResource ModernCard}" Background="#DBEAFE" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Employees" Foreground="#1E3A8A" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalEmployees}" FontSize="28" FontWeight="Bold" Foreground="#1D4ED8" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCard}" Background="#DCFCE7" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Present Today" Foreground="#166534" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding PresentToday}" FontSize="28" FontWeight="Bold" Foreground="#16A34A" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCard}" Background="#FFEDD5" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Late Today" Foreground="#9A3412" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LateToday}" FontSize="28" FontWeight="Bold" Foreground="#EA580C" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource ModernCard}" Background="#FEE2E2">
                <StackPanel>
                    <TextBlock Text="Absent Today" Foreground="#991B1B" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AbsentToday}" FontSize="28" FontWeight="Bold" Foreground="#DC2626" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource ModernCard}" Margin="0,0,0,14">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="Birthday Celebrants Today" Style="{StaticResource SectionTitle}" FontWeight="Bold" />
                    <materialDesign:PackIcon Kind="CakeVariant" Width="20" Height="20" Foreground="#D97706" Margin="8,0,0,0" />
                </DockPanel>

                <TextBlock Text="No birthdays today."
                           Foreground="#6B7280"
                           Visibility="{Binding BirthdayCelebrants.Count, Converter={StaticResource ZeroToVisibility}}"
                           Margin="0,8,0,0" />

                <ItemsControl ItemsSource="{Binding BirthdayCelebrants}" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFF8DB" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,10" MinWidth="190">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="46" Height="46" Margin="0,0,10,0">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfileImage, Converter={StaticResource ByteToImage}}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding EmployeeCode}" Foreground="#6B7280" FontSize="12" />
                                        <TextBlock Text="{Binding Label}" Foreground="#92400E" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

            <Border Grid.Row="3" Style="{StaticResource ModernCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Latest Attendance Records" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding LatestAttendances}"
                              Style="{StaticResource ModernDataGrid}"
                              Margin="0,8,0,0"
                              MinHeight="220"
                              MaxHeight="360"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding EmployeeCode}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="220" />
                            <DataGridTextColumn Header="Date" Binding="{Binding AttendanceDate, StringFormat=yyyy-MM-dd}" Width="120" />
                            <DataGridTextColumn Header="Time In" Binding="{Binding TimeIn, StringFormat=HH:mm}" Width="90" />
                            <DataGridTextColumn Header="Time Out" Binding="{Binding TimeOut, StringFormat=HH:mm}" Width="90" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
